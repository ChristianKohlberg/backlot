{
  "name": "backlot",
  "version": "0.5.0",
  "description": "The repo-aware environment broker: puts a working, seeded, provable instance of your web application in front of coding agents and humans \u2014 warm pools, leases, bind-by-sync. Brokers environments; never provides them.",
  "keywords": [
    "environment",
    "broker",
    "dev-environment",
    "coding-agents",
    "e2e",
    "preview",
    "warm-pool",
    "sandbox",
    "harness",
    "mcp"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "backlot": "dist/cli/index.js",
    "backlot-mcp": "dist/mcp/index.js"
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "pretest": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "yaml": "^2.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChristianKohlberg/backlot.git"
  },
  "homepage": "https://github.com/ChristianKohlberg/backlot#readme",
  "bugs": {
    "url": "https://github.com/ChristianKohlberg/backlot/issues"
  },
  "author": "Christian Kohlberg"
}
