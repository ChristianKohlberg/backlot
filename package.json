{
  "name": "infront",
  "version": "0.4.0",
  "description": "The repo-aware environment broker: puts a working, seeded, provable instance of your web application in front of coding agents and humans — warm pools, leases, bind-by-sync. Brokers environments; never provides them.",
  "keywords": [
    "dev-environment",
    "agents",
    "e2e",
    "environments",
    "broker",
    "warm-pool",
    "playwright"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "infront": "./dist/cli/index.js",
    "infront-mcp": "./dist/mcp/index.js"
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "pretest": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "yaml": "^2.6.0"
  }
}
